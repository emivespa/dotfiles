# https://editorconfig.org/

root = true

[*]
# Standards:
encoding = utf-8
end_of_line = lf
insert_final_newline = true
# Preferences and fallbacks:
indent_size = 8
indent_style = tab
# Convenience:
trim_trailing_whitespace = true

# General purpose convention and style guide compliance:
[*.{js,json}]
indent_size = 2
indent_style = space
[*.py]
indent_size = 4
indent_style = space
[*.go]
indent_style = tab

# Language quirk compliance:
[Makefile,*.scd]
indent_style = tab
[*.go]
encoding = utf-8
